# Configuration Template
# Copy this to .env and customize for your setup

# Camera Configuration
CAMERA_ID=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15

# Detection Configuration
MODEL=yolov5n
CONFIDENCE_THRESHOLD=0.45
SKIP_FRAMES=2
ENABLE_DISPLAY=false

# LoRa Configuration
LORA_PORT=/dev/ttyUSB0
LORA_BAUDRATE=115200
LORA_COOLDOWN_SECONDS=30

# IP Geolocation Configuration
# Approximate public-IP location, not true GPS.
LOCATION_UPDATE_INTERVAL=25
LOCATION_TIMEOUT=3.0
LOCATION_RETRIES=2
LOCATION_API_URL=https://ipinfo.io/json

# Logging Configuration
LOG_DIRECTORY=logs
ENABLE_FILE_LOGGING=true
LOG_LEVEL=INFO

# Performance Tuning
MAX_MEMORY_MB=512
FRAME_QUEUE_SIZE=1
USE_HALF_PRECISION=false

# Features
ENABLE_MOTION_DETECTION=false
ENABLE_CLOUD_SYNC=false
ENABLE_WEB_DASHBOARD=false

# Notes:
# - CAMERA_ID: 0 for first camera, 1 for second, etc.
# - SKIP_FRAMES: 1 = no skip, 2 = every 2nd frame, etc.
# - LORA_COOLDOWN_SECONDS: Minimum seconds between messages of same type
# - LOCATION_UPDATE_INTERVAL: Minimum seconds between IP geolocation API calls
